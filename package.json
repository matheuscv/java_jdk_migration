{
  "name": "jdk-migration-mcp",
  "version": "0.3.41",
  "description": "MCP server that orchestrates Java JDK 6/8 → 21 migrations with human-in-the-loop gates",
  "type": "module",
  "main": "dist/mcp-server/index.js",
  "bin": {
    "jdk-migration-mcp": "dist/mcp-server/index.js"
  },
  "files": [
    "dist/",
    "config/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');const src='src/knowledge-base/data';const dst='dist/knowledge-base/data';fs.mkdirSync(dst,{recursive:true});fs.readdirSync(src).forEach(f=>fs.copyFileSync(src+'/'+f,dst+'/'+f));\"",
    "prepare": "npm run build",
    "prepublishOnly": "npm test",
    "dev": "tsx watch src/mcp-server/index.ts",
    "start": "node dist/mcp-server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "java",
    "jdk",
    "migration",
    "openrewrite",
    "java-21",
    "jdk-migration",
    "model-context-protocol",
    "claude",
    "anthropic"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/matheuscv/java_jdk_migration"
  },
  "homepage": "https://github.com/matheuscv/java_jdk_migration#readme",
  "bugs": {
    "url": "https://github.com/matheuscv/java_jdk_migration/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
